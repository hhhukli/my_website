        let currentIndex = 0;
        
        const moodDate = document.getElementById('mood-date');
        const moodContent = document.getElementById('mood-content');
        const moodDot = document.getElementById('mood-dot');
        const btnPrev = document.getElementById('btn-prev');
        const btnNext = document.getElementById('btn-next');

        function renderMood() {
            moodContent.classList.remove('opacity-100');
            moodContent.classList.add('opacity-0');
            
            setTimeout(() => {
                const isLatest = currentIndex === 0;
                moodDate.innerText = moods[currentIndex].date + (isLatest ? " / Live Updates" : " / Archive");
                moodContent.innerHTML = moods[currentIndex].content;
                
                if(isLatest) {
                    moodDot.classList.add('animate-pulse', 'bg-green-400');
                    moodDot.classList.remove('bg-gray-300');
                } else {
                    moodDot.classList.remove('animate-pulse', 'bg-green-400');
                    moodDot.classList.add('bg-gray-300');
                }

                btnPrev.disabled = currentIndex === moods.length - 1;
                btnNext.disabled = currentIndex === 0;
                
                btnPrev.style.opacity = btnPrev.disabled ? '0.2' : '1';
                btnPrev.style.cursor = btnPrev.disabled ? 'not-allowed' : 'pointer';
                btnNext.style.opacity = btnNext.disabled ? '0.2' : '1';
                btnNext.style.cursor = btnNext.disabled ? 'not-allowed' : 'pointer';

                moodContent.classList.remove('opacity-0');
                moodContent.classList.add('opacity-100');
            }, 200); 
        }

        btnPrev.addEventListener('click', () => {
            if (currentIndex < moods.length - 1) {
                currentIndex++;
                renderMood();
            }
        });

        btnNext.addEventListener('click', () => {
            if (currentIndex > 0) {
                currentIndex--;
                renderMood();
            }
        });

        renderMood();
    </script>
