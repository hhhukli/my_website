const thoughtsAll = [
    {
        title: "像训练AI模型一样训练自己，Attention is all my power",
        date: "2026.04.30 / Xiaohongshu",
        link: "https://www.xiaohongshu.com/explore/69f371d00000000022027461?xsec_token=ABXLX_IicB-krB-VYzborFc4VatQdWvK1gweQv0Xd0C68=&xsec_source=pc_user"
    },
    {
        title: "AI时代，是对人的主体性的呼唤，君子不器",
        date: "2026.04.23 / Xiaohongshu",
        link: "https://www.xiaohongshu.com/explore/69ea40ee0000000022025990?xsec_token=AB0Jv6VH_AFK3XTYeNnbEexh-blMevhf93Jywsos8_Q3s=&xsec_source=pc_user"
    },
    {
