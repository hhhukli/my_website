---
import '../styles/global.css';

// 🚨 你的“小红书随笔数据库” 🚨
// 以后发了新帖子，直接在这里复制加上 { title: "...", date: "...", link: "..." } 就行！
const thoughts = [
    {
        title: "大学生活的“轻松与随便”毁了我",
        date: "2026.04.11 / Xiaohongshu",
        link: "https://www.xiaohongshu.com/explore/69d5a012000000001a02ed3b?xsec_token=ABfml7phlbjMa50f-w2urwz11SYkLQwbiVzZBbIIFXT0E=&xsec_source=pc_user"
    },
    {
        title: "浅谈大学水课和硬课",
        date: "2026.04.10 / Xiaohongshu",
        link: "https://www.xiaohongshu.com/explore/69cdb21a00000000230161d2?xsec_token=ABNG_OG1eRDnobAAYIQxHSm8mRqVY4N0JbgSHHJDv89Kc=&xsec_source=pc_user"
    },
    {
        title: "认知实习报告",
        date: "2026.04.09 / Xiaohongshu",
        link: "https://www.xiaohongshu.com/explore/69cccea9000000002301f579?xsec_token=ABEM7wm3Qo1rBWkSz1Y_xgM7b0aQC7dHO7Y67NnZz6V6o=&xsec_source=pc_user"
    },
    {
        title: "“你变了”和“我眼镜找不到了”的量子纠缠关系",
        date: "2026.04.08 / Xiaohongshu",
        link: "https://www.xiaohongshu.com/explore/69b9ea80000000001f001dc8?xsec_token=ABhuvVN7xXveC-Ghi8Vsj2ckE7DllgR0i-5vT8vhTz3EE=&xsec_source=pc_user"
    }
];
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thoughts - QUANZARD Studio</title>
    <style>
        .custom-bg { background-color: #EAEAEA !important; }
    </style>
</head>
<body class="custom-bg text-[#111111] antialiased md:text-sm">

    <nav class="p-6 md:p-10 max-w-[1000px] mx-auto flex items-center justify-between">
        <a href="/" class="text-xs font-mono tracking-widest text-gray-500 hover:text-[#002FA7] transition-colors flex items-center group">
            <span class="mr-2 transform group-hover:-translate-x-1 transition-transform">&larr;</span> BACK TO HOME
        </a>
        <div class="text-xs font-bold tracking-widest text-[#FF4500]">QUANZARD.</div>
    </nav>

    <header class="pt-10 pb-16 max-w-[1000px] mx-auto px-6">
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tighter text-[#111111]">
            ALL <span class="text-[#002FA7]">THOUGHTS.</span>
        </h1>
        <p class="mt-4 text-gray-500 font-light max-w-xl">
            这里记录了我的所有碎碎念、设计复盘和突发奇想。点击卡片跳转至小红书。
        </p>
    </header>

    <main class="max-w-[1000px] mx-auto px-6 pb-24 space-y-4">
        {thoughts.map((thought) => (
            <a href={thought.link} target="_blank" class="group block p-6 md:p-8 bg-white border border-gray-200/60 rounded-xl hover:border-[#FF4500] hover:shadow-[0_8px_30px_rgb(255,69,0,0.1)] transition-all duration-300 flex flex-col md:flex-row md:items-center justify-between">
                <div class="flex-1 pr-4">
                    <h3 class="text-lg md:text-xl font-bold text-[#111111] group-hover:text-[#FF4500] transition-colors leading-snug">{thought.title}</h3>
                    <p class="text-xs text-gray-400 font-mono mt-3 md:mt-4 border-l-2 border-[#FF4500] pl-2">{thought.date}</p>
                </div>
                <span class="hidden md:block text-gray-300 group-hover:text-[#FF4500] text-2xl transform group-hover:translate-x-1 group-hover:-translate-y-1 transition-all">↗</span>
            </a>
        ))}
    </main>

    <footer class="border-t border-gray-300/50">
        <div class="max-w-[1000px] mx-auto px-6 py-12 text-center text-xs font-mono tracking-widest text-gray-500">
            &copy; 2026 QUANZARD. BUILT WITH AI & AFFECTION.
        </div>
    </footer>

</body>
</html>