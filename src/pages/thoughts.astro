---
import '../styles/global.css';
import { thoughtsCollectionToc } from '../data/thoughtsCollectionToc';

// 🚨 你的“小红书随笔数据库” 🚨
// 以后发了新帖子，在 thoughtsAll 里追加 { title, date, link } 即可。
// 节选：默认展示前 EXCERPT_COUNT 条；合辑：展示全部。若要「合辑」改为小红书合集链接，可把 thoughtsCollection 改成独立数组。
//{
//        title: "",
//        date: "2026.04.18 / Xiaohongshu",
//        link: ""
//    },
