---
import '../styles/global.css';

// 🚨 你的“动态影像数据库” 🚨
// 以后发新视频，直接在这里复制加上 { title: "...", date: "...", link: "...", imgSrc: "..." } 就行！
const videos = [
    {
        title: "Ring 动态混剪", // 👈 这里可以改成你想要的真实标题
        date: "MOTION / 2026",
        link: "https://www.bilibili.com/video/BV1USDTBfERM?t=57.4",
        imgSrc: "./ring.jpg" // 确保你的图片在 public 文件夹下，且后缀正确
    },
    {
        title: "Car 极限竞速录像", // 👈 这里可以改成你想要的真实标题
        date: "MOTION / 2026",
        link: "https://www.bilibili.com/video/BV1ctQmBcEwv?t=1.1",
        imgSrc: "./car.jpg"
    },
    {
        title: "Falling Cat 趣味集锦", // 👈 这里可以改成你想要的真实标题
        date: "MOTION / 2026",
        link: "https://www.bilibili.com/video/BV1HjDxBNEa6?t=3.0",
        imgSrc: "./fallingcat.jpg"
    }
];
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Videos - QUANZARD Studio</title>
    <style>
        .custom-bg { background-color: #EAEAEA !important; }
    </style>
</head>
<body class="custom-bg text-[#111111] antialiased">

    <nav class="p-6 md:p-10 max-w-[1400px] mx-auto flex items-center justify-between">
        <a href="/" class="text-xs font-mono tracking-widest text-gray-500 hover:text-[#002FA7] transition-colors flex items-center group">
            <span class="mr-2 transform group-hover:-translate-x-1 transition-transform">&larr;</span> BACK TO HOME
        </a>
        <div class="text-xs font-bold tracking-widest text-[#FF4500]">QUANZARD.</div>
    </nav>

    <header class="pt-10 pb-12 max-w-[1400px] mx-auto px-6">
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tighter text-[#111111]">
            MOTION <span class="text-[#002FA7]">ARCHIVE.</span>
        </h1>
        <p class="mt-4 text-sm text-gray-500 font-light max-w-xl">
            动态影像与剪辑作品。点击卡片前往 Bilibili 观看高清版本。
        </p>
    </header>

    <main class="max-w-[1400px] mx-auto px-6 pb-24 grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 md:gap-6">
        
        {videos.map((vid) => (
            <a href={vid.link} target="_blank" class="bg-white p-3 rounded-xl border border-gray-200/80 shadow-sm hover:shadow-md transition-all hover:-translate-y-1 group flex flex-col">
                <div class="overflow-hidden rounded-lg aspect-video relative bg-gray-100">
                    <img src={vid.imgSrc} alt={vid.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />
                    <div class="absolute inset-0 bg-black/10 group-hover:bg-black/20 transition-colors duration-300 flex items-center justify-center">
                        <div class="w-10 h-10 bg-white/90 backdrop-blur-sm rounded-full flex items-center justify-center transform group-hover:scale-110 transition-transform shadow-sm">
                            <svg class="w-4 h-4 text-[#FF4500] ml-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"></path></svg>
                        </div>
                    </div>
                </div>
                <div class="pt-3 pb-1 px-1">
                    <div class="flex justify-between items-start">
                        <h3 class="text-sm font-bold text-[#111111] tracking-tight group-hover:text-[#002FA7] transition-colors leading-snug line-clamp-1">{vid.title}</h3>
                    </div>
                    <p class="text-[10px] text-gray-400 font-mono mt-1">{vid.date}</p>
                </div>
            </a>
        ))}

    </main>

    <footer class="border-t border-gray-300/50">
        <div class="max-w-[1400px] mx-auto px-6 py-12 text-center text-xs font-mono tracking-widest text-gray-500">
            &copy; 2026 QUANZARD. BUILT WITH AI & AFFECTION.
        </div>
    </footer>

</body>
</html>